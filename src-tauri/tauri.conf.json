{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Kakebo",
  "version": "0.1.0",
  "identifier": "com.kakebo.app",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm run dev",
    "beforeBuildCommand": "pnpm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Kakebo",
        "label": "main",
        "width": 900,
        "height": 700,
        "minWidth": 600,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "Gestión de finanzas personales",
    "longDescription": "Kakebo App - Aplicación de escritorio para gestión de finanzas personales basada en el método Kakebo japonés"
  }
}
